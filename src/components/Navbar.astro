---
// Componente de navegación estático
const systemUrl = import.meta.env.PUBLIC_SYSTEM_URL;
---
<nav>
  <a href="#" class="nav-brand"><span>🌿</span> Vivero La Vega</a>
  <a href={systemUrl} class="nav-cta">Acceder</a>
</nav>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-brand {
    display: flex; align-items: center; gap: .6rem;
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem; font-weight: 700;
    color: var(--green-main);
    text-decoration: none;
  }
  .nav-brand span { font-size: 1.5rem; }
  .nav-cta {
    background: var(--green-main); color: var(--white);
    padding: .55rem 1.4rem; border-radius: 8px;
    text-decoration: none; font-weight: 600; font-size: .9rem;
    transition: background .2s, transform .15s;
  }
  .nav-cta:hover { background: var(--green-dark); transform: translateY(-1px); }

  @media (max-width: 600px) {
    nav { padding: 1rem 1.2rem; }
  }
</style>