---
// src/components/Cta.astro
---
<section class="cta-section">
  <div class="container fade-up">
    <h2>¿Listo para modernizar tu vivero?</h2>
    <p>Accede al sistema ahora mismo. Sin instalaciones, sin complicaciones.</p>
    <a href="https://viveros-ecuador.devxsota.cloud" class="btn-white">
      <span class="material-icons">rocket_launch</span>
      Entrar al Sistema
    </a>
  </div>
</section>

<style>
  .container { max-width: 1100px; margin: 0 auto; }
  .cta-section {
    background: linear-gradient(135deg, var(--green-main) 0%, var(--green-dark) 100%);
    text-align: center; padding: 6rem 2rem;
  }
  .cta-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: var(--white); margin-bottom: 1rem;
  }
  .cta-section p { color: rgba(255,255,255,.8); font-size: 1.1rem; margin-bottom: 2.5rem; }
  .btn-white {
    background: var(--white); color: var(--green-dark);
    padding: .95rem 2.2rem; border-radius: 10px;
    text-decoration: none; font-weight: 700; font-size: 1rem;
    display: inline-flex; align-items: center; gap: .5rem;
    transition: transform .15s, box-shadow .2s;
    box-shadow: 0 4px 16px rgba(0,0,0,.2);
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.25); }
  .btn-white .material-icons { font-size: 1.1rem; }
</style>