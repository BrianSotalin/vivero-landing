---
// src/layouts/Layout.astro
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌿</text></svg>" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  </head>
  <body>
    <!-- Aquí se renderizarán las páginas que usen este layout -->
    <slot />

    <script>
      // Tu script de intersección para las animaciones fade-up se ejecuta aquí de forma eficiente
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  /* Aquí colocas todos tus estilos base, variables de color (:root) y animaciones */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green-dark:   #1b5e20;
    --green-main:   #2e7d32;
    --green-mid:    #388e3c;
    --green-light:  #66bb6a;
    --green-pale:   #e8f5e9;
    --green-mist:   #f1f8e9;
    --accent:       #8bc34a;
    --gold:         #f9a825;
    --white:        #ffffff;
    --text:         #1a2e1a;
    --text-muted:   #557a55;
    --border:       #c8e6c9;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    background: var(--white);
    overflow-x: hidden;
  }

  /* Animaciones globales */
  .fade-up {
    opacity: 0; transform: translateY(24px);
    transition: opacity .6s ease, transform .6s ease;
  }
  .fade-up.visible { opacity: 1; transform: translateY(0); }
</style>