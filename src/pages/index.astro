---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Advantages from '../components/Advantages.astro';
import Tech from '../components/Tech.astro';
import Roles from '../components/Roles.astro';
import Cta from '../components/Cta.astro';
---

<Layout title="Vivero La Vega — Sistema de Gestión">
  <Navbar />
  <main>
    <Hero />
    <Features />
    <Advantages />
    <Tech />
    <Roles />
    <Cta />
  </main>
  
  <footer>
    <p>🌿 Vivero La Vega &mdash; Desarrollado por <a href="https://devxsota.cloud" target="_blank">Dev Sota Cloud</a> &copy; 2026</p>
  </footer>
</Layout>

<style>
  footer {
    background: var(--text); color: rgba(255,255,255,.5);
    text-align: center; padding: 2rem;
    font-size: .85rem;
  }
  footer a { color: var(--accent); text-decoration: none; }
</style>